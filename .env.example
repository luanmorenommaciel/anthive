# anthive — environment variables
#
# Copy to .env (gitignored) and fill in. Never commit real keys.

# ══════════════════════════════════════════════════════════════════════════════
# Langfuse (observability backend)
# ══════════════════════════════════════════════════════════════════════════════
# Get these from http://localhost:3000 after running
#   docker compose -f docker/langfuse-compose.yml up -d
# and creating a project named "anthive"

LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxx
LANGFUSE_HOST=http://localhost:3000


# ══════════════════════════════════════════════════════════════════════════════
# Claude Code telemetry (enables native OTEL export)
# ══════════════════════════════════════════════════════════════════════════════
# anthive sets these in the dispatched child process — you don't need them
# in your shell unless you're debugging.

# CLAUDE_CODE_ENABLE_TELEMETRY=1
# CLAUDE_CODE_ENHANCED_TELEMETRY_BETA=1
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3000/api/public/otel


# ══════════════════════════════════════════════════════════════════════════════
# Anthropic Console API key (CLOUD MODE ONLY)
# ══════════════════════════════════════════════════════════════════════════════
# Required ONLY if you use `anthive dispatch --cloud`.
# Local mode uses your Claude Max subscription (no API key needed).
#
# Get a key: https://console.anthropic.com/settings/keys
# This bills Console credits, NOT your Max subscription.

# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx


# ══════════════════════════════════════════════════════════════════════════════
# Slack notifications (optional)
# ══════════════════════════════════════════════════════════════════════════════
# Incoming webhook URL; used when session hits BLOCKED or exceeds budget.

# SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ
